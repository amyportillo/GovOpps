# .env.example
# Copy this file to .env and fill in your real values.
# .env is never committed to GitHub — this example file is safe to share.
#
#   cp .env.example .env

# SAM.gov API 
# Get a free API key at https://sam.gov/ → sign up → API keys
SAM_API_KEY=YOUR_API_KEY_HERE

# Optional: restrict which date range to fetch contracts for (format: MM/dd/yyyy)
# Leave blank to automatically use the last 7 days
SAM_POSTED_FROM=
SAM_POSTED_TO=

# PostgreSQL Database
# These must match your local PostgreSQL setup 
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gov_contracts_dw
DB_USER=postgres
DB_PASSWORD=your_database_password_here
